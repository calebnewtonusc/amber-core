# Postgres + pgvector
DATABASE_URL=postgresql://user:password@host:5432/amber

# Claude / Anthropic
CLAUDE_API_KEY=sk-ant-...

# OpenAI (for embeddings via text-embedding-3-small)
OPENAI_API_KEY=sk-...

# GCP Cloud Storage
GCP_PROJECT_ID=your-gcp-project-id
GCP_STORAGE_BUCKET=amber-assets
# Either a key file path or the JSON string directly:
GCP_KEY_FILE=/path/to/service-account.json
# GCP_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Auth (shared secret for agent <-> API)
AMBER_API_KEY=your_secret_api_key
AMBER_USER_ID=sagar

# Redis (optional — for job queue and rate limiting)
REDIS_URL=redis://...

# Railway (set automatically)
PORT=8080
